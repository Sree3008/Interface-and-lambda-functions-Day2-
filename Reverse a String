// Reverse a String
import java.util.*;
@FunctionalInterface
interface Length{
    String StringLenth(String len);
}
class Main{
    public static void main(String[] args){
        Scanner ob=new Scanner(System.in);
        String str=ob.nextLine();
        Length le=(str1)->{
            String s="";
            char[] st=str1.toCharArray();
            for(int i=str1.length()-1;i>=0;i--){
                s+=st[i];
            }
            return s;
        };
        System.out.print(le.StringLenth(str));
    }
}
